
generator client {
  provider = "prisma-client"
  output = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}   

enum FlwStepType{
  Trigger
  Action
} 

enum FlwStatus {
  Draft
  Active
  Paused
  Archived
}
  
enum FlwExecutionStatus{
  Pending
  Success
  Failed
  Running
}

enum FlwConditionSourceType{
  Trigger
  StepOutput
}

enum FlwConditionOperator{
  Equals
  NotEquals
  Contains
  NotContains
  GreaterThan
  LessThan
  Exists
  NotExists
}

enum FlwConditionLogicGate{
  And
  Or
}

model Flw{
  id                          String @id @default(uuid())        
  name                        String
  eventKey                    String?   @unique
  webhookKey                  String? @unique  
  FlwSteps                    FlwSteps[]
  FlwConditions               FlwConditions[]
  FlwExecutions               FlwExecutions[]
  ProcessedEvents             ProcessedEvents[]
  status                      FlwStatus @default(Draft)
  createdAt                   DateTime   @default(now())
}

model FlwSteps{
  id                          String @id @default(uuid())
  Flw              Flw        @relation(fields: [flwId], references: [id])
  flwId                       String
  name                        String?
  position                    Int
  type                        FlwStepType
  integrationKey              String
  operationKey                String?
  configPayload               Json?
  inputMapping                Json?

  parentStepId                String?
  branchIndex                 Int @default(0)
  parentStep                  FlwSteps? @relation("StepBranches", fields: [parentStepId], references: [id])
  childSteps                  FlwSteps[] @relation("StepBranches")

  FlwExecutionSteps           FlwExecutionSteps[]
  FlwConditions               FlwConditions[]

  @@index([flwId, parentStepId, branchIndex, position])
}

model FlwExecutions{
  id                          String @id @default(uuid())
  Flw              Flw        @relation(fields: [flwId], references: [id])
  flwId                       String
  lockedBy                    String?  
  idempotencyKey              String?                   
  status                      FlwExecutionStatus
  FlwExecutionSteps           FlwExecutionSteps[]                        
  ProcessedEvents             ProcessedEvents?
  lockedAt                    DateTime?
  triggerPayload              Json?
  triggeredAt                 DateTime   @default(now())
  startedAt                   DateTime?
  finishedAt                  DateTime?
}

model FlwExecutionSteps {
  id               String @id @default(uuid())
  flwExecutionId   String
  flwStepId        String

  status           FlwExecutionStatus
  retryCount       Int @default(0)

  error            String?
  outputPayload    Json?
  errorPayload     Json?
  idempotencyKey   String?

  startedAt        DateTime?
  finishedAt       DateTime?

  nextRetryAt     DateTime?

  FlwExecutions    FlwExecutions @relation(fields: [flwExecutionId], references: [id])
  FlwSteps         FlwSteps @relation(fields: [flwStepId], references: [id])
}

model FlwConditions{
  id                          String @id @default(uuid())
  Flw                         Flw @relation(fields: [flwId], references: [id])
  flwId                       String
  FlwSteps                    FlwSteps? @relation(fields: [flwStepId], references: [id])
  flwStepId                   String?
  sourceType                  FlwConditionSourceType
  sourceStepId                String?
  fieldPath                   String
  operator                    FlwConditionOperator
  comparisonValue             Json?
  logicGate                   FlwConditionLogicGate @default(And)
  position                    Int

  @@index([flwId, flwStepId, position])
}

model ProcessedEvents{
  id                          String @id @default(uuid())
  eventKey                    String  @unique 
  Flw              Flw        @relation(fields: [flwId], references: [id])
  flwId                       String
  flwExecutionId              String?  @unique
  FlwExecutions               FlwExecutions? @relation(fields: [flwExecutionId], references: [id])
  processedAt                 DateTime   @default(now())
}
