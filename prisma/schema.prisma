
generator client {
  provider = "prisma-client"
  output = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}   

enum FlwStepType{
  Trigger
  Action
} 

enum FlwStatus {
  Draft
  Active
  Paused
  Archived
}
  
enum FlwExecutionStatus{
  Pending
  Success
  Failed
  Running
}

model Flw{
  id                          String @id @default(uuid())        
  name                        String
  eventKey                    String?   @unique
  webhookKey                  String? @unique  
  FlwSteps                    FlwSteps[]
  FlwExecutions               FlwExecutions[]
  ProcessedEvents             ProcessedEvents[]
  status                      FlwStatus @default(Draft)
  createdAt                   DateTime   @default(now())
}

model FlwSteps{
  id                          String @id @default(uuid())
  Flw              Flw        @relation(fields: [flwId], references: [id])
                              @@unique([flwId, position])
  flwId                       String
  name                        String?
  position                    Int
  type                        FlwStepType
  FlwExecutionSteps           FlwExecutionSteps[]
  integrationKey              String
  operationKey                String?
  configPayload               Json?
  inputMapping                Json?
}

model FlwExecutions{
  id                          String @id @default(uuid())
  Flw              Flw        @relation(fields: [flwId], references: [id])
  flwId                       String
  lockedBy                    String?  
  idempotencyKey              String?                   
  status                      FlwExecutionStatus
  FlwExecutionSteps           FlwExecutionSteps[]                        
  ProcessedEvents             ProcessedEvents?
  lockedAt                    DateTime?
  triggerPayload              Json?
  triggeredAt                 DateTime   @default(now())
  startedAt                   DateTime?
  finishedAt                  DateTime?
}

model FlwExecutionSteps {
  id               String @id @default(uuid())
  flwExecutionId   String
  flwStepId        String

  status           FlwExecutionStatus
  retryCount       Int @default(0)

  error            String?
  outputPayload    Json?
  errorPayload     Json?
  idempotencyKey   String?

  startedAt        DateTime?
  finishedAt       DateTime?

  nextRetryAt     DateTime?

  FlwExecutions    FlwExecutions @relation(fields: [flwExecutionId], references: [id])
  FlwSteps         FlwSteps @relation(fields: [flwStepId], references: [id])
}


model ProcessedEvents{
  id                          String @id @default(uuid())
  eventKey                    String  @unique 
  Flw              Flw        @relation(fields: [flwId], references: [id])
  flwId                       String
  flwExecutionId              String?  @unique
  FlwExecutions               FlwExecutions? @relation(fields: [flwExecutionId], references: [id])
  processedAt                 DateTime   @default(now())
}
